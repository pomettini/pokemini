# CMake build directories — regenerated by cmake/make.
build/
build-device*/

# Build artifacts that pdc and the SDK build scripts drop into Source/.
# Source/pdxinfo is a real source file; the binaries below are not.
Source/pdex.dylib
Source/pdex.elf
Source/pdex.bin

# Compiled .pdx bundle. Rebuilt on every cmake invocation, no point versioning.
*.pdx/

# AI coding assistant artifacts (machine-specific, never tracked).
.claude/
.codex/
AGENTS.md

# macOS / editor / IDE noise
.DS_Store
.vscode/
.idea/
*.swp
*~
